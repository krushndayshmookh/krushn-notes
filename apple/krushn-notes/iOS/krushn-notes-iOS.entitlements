<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Group shared with Widget extension for WidgetSharedModels data -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.krushn.notes</string>
    </array>

    <!-- Keychain access group shared with widget -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)com.krushn.notes.shared</string>
    </array>
</dict>
</plist>
